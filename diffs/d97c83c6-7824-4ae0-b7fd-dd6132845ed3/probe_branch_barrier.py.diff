 import os
 
 from flask import request
 
 
 def length_checked(x):
     # 有分支 + raise，形狀跟 ensure_allowed_table 一樣，但長度檢查『不淨化』：
     # 回傳值仍是完整的攻擊者可控字串，可注入。
     if len(x) > 4096:
         raise ValueError("too long")
     return x
 
 
 def probe_branch_no_sanitize():
     term = request.args.get("q", "")   # 已知 source
     t = length_checked(term)           # 有分支但不淨化
     os.system("echo " + t)             # 已知 sink -> 真實可注入
     return "done"
 
 
 def alnum_only(x):
     # 轉換型淨化：只留英數字，輸出不可能含 shell/SQL 中繼字元 -> 實際安全。
     return "".join(ch for ch in x if ch.isalnum())
 
 
